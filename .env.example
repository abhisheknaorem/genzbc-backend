# Database (Neon PostgreSQL)
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/atang_crm?sslmode=require"
DATABASE_URL="postgresql://neondb_owner:npg_CS6a5NkJwxKn@ep-empty-truth-a1vj6jnd-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT
JWT_ACCESS_SECRET="change-this-access-secret-in-production"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# AWS S3 (or Cloudflare R2 — R2 is S3-compatible)
STORAGE_PROVIDER="s3"          # "s3" or "r2"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET="your-bucket-name"

# For Cloudflare R2 (leave AWS fields blank if using R2)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET="your-r2-bucket-name"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# Server
PORT=4000
CLIENT_URL="http://localhost:3000"
NODE_ENV="development"
